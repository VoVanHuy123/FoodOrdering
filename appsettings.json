{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "${DefaultConnection}"
  },
  "CloudinarySettings": {
    "CloudName": "${CloudName}",
    "ApiKey": "${CloudApiKey}",
    "ApiSecret": "${CloudApiSecret}"
  },
  "AppUrl": "${AppUrl}"
}