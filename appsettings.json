{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "${DefaultConnection}"
  },
  "CloudinarySettings": {
    "CloudName": "${CloudName}",
    "ApiKey": "${CloudApiKey}",
    "ApiSecret": "${CloudApiSecret}"
  },
  "AppUrl": "${AppUrl}",
  "NetworkAccess": {
    "RestaurantIp": "192.168.2.1",
    "SubnetMask": "255.255.255.0"
  }
}