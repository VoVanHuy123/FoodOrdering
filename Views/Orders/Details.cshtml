@model FoodOrdering.DTOs.OrderDTO

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-4">

    <div class="row">

        <!-- ================= LEFT : ORDER INFO ================= -->
        <div class="col-lg-4">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🧾 Order Information</h5>
                </div>

                <div class="card-body">

                    <p>
                        <strong>🍽 Table:</strong>
                        <span class="fw-bold">#@Model.TableId</span>
                    </p>

                    <p>
                        <strong>⏰ Order Time:</strong><br />
                        @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")
                    </p>

                    <p>
                        <strong>Status:</strong><br />

                        <span class="badge
                            @(Model.Status == "Completed" ? "bg-success" :
                                                            Model.Status == "Pending" ? "bg-warning text-dark" :
                                                            "bg-secondary")">

                            @Model.Status
                        </span>
                    </p>

                    <hr />

                    <h4 class="text-danger fw-bold">
                        Total: @Model.TotalAmount.ToString("N0") VNĐ
                    </h4>

                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="alert alert-light mt-3">
                            📝 @Model.Note
                        </div>
                    }

                </div>

                <div class="card-footer text-center bg-white">

                    <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Index"
                           class="btn btn-secondary btn-sm">
                        Back
                    </a>

                </div>

            </div>

        </div>

        <!-- ================= RIGHT : ORDER ITEMS ================= -->
        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">🍔 Ordered Items</h5>
                </div>

                <div class="card-body">

                    @if (Model.Items == null || !Model.Items.Any())
                    {
                        <div class="alert alert-info">
                            No items in this order.
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <div class="d-flex align-items-center mb-4 border-bottom p-3 @((item.IsAvailable == false) ? "border-warning bg-warning-subtle" : "")">

                                <!-- IMAGE -->
                                <img src="@Url.Content(item.ImageUrl ?? "~/imgs/food.png")"
                                     width="80"
                                     height="80"
                                     class="rounded shadow-sm me-3"
                                     style="object-fit:cover;" />

                                <!-- INFO -->
                                <div class="flex-grow-1">

                                    <h5 class="mb-1 fw-bold">
                                        @item.MenuItemName
                                    </h5>

                                    <div class="text-muted">
                                        Price:
                                        @item.Price.ToString("N0") VNĐ
                                    </div>

                                    @if (!string.IsNullOrEmpty(item.Note))
                                    {
                                        <div class="small text-secondary">
                                            📝 @item.Note
                                        </div>
                                    }

                                </div>

                                <!-- QUANTITY -->
                                <div class="text-end">

                                    <span class="badge bg-primary fs-6">
                                        x @item.Quantity
                                    </span>

                                    <div class="fw-bold text-danger mt-2">
                                        @((item.Price * item.Quantity).ToString("N0")) VNĐ
                                    </div>

                                </div>

                            </div>
                        }
                    }

                </div>

            </div>

        </div>

    </div>

</div>