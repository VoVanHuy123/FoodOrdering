@model FoodOrdering.DTOs.PagedResult<FoodOrdering.DTOs.OrderDTO>

@{
    var query = ViewBag.Query as FoodOrdering.DTOs.OrderQuery;
}
 <style>
    .card {
        transition: 0.3s;
        border-radius: 10px;
    }
    .card:hover {
        transform: translateY(-5px);
    } 
</style> 

<div class="container mt-4">

    <!-- HEADER -->
    @* <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🧾 Order Management</h2>

        <a asp-action="Create" class="btn btn-success">
            + Create Order
        </a>
    </div> *@

    <!-- SEARCH + FILTER -->
    <form method="get" class="row g-3 mb-4">

        <div class="col-md-3">
            <input name="TableNumber"
                   value="@query?.TableNumber"
                   class="form-control"
                   placeholder="Table Number" />
        </div>

        <div class="col-md-3">
            <select name="Status" class="form-select">

                <option value="">All Status</option>
                <option value="Preparing"
                        selected="@(query?.Status == "Preparing")">
                    Preparing
                </option>
                <option value="Pending"
                        selected="@(query?.Status == "Pending")">
                    Pending
                </option>

                <option value="Completed"
                        selected="@(query?.Status == "Completed")">
                    Completed
                </option>

                <option value="Cancelled"
                        selected="@(query?.Status == "Cancelled")">
                    Cancelled
                </option>

            </select>
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">
                Search
            </button>
        </div>
        <div class="col-md-2">
            <a asp-action="Create" class="btn btn-success">
            + Create Order
        </a>
        </div>
           
    </form>

    <!-- ORDER CARDS -->
    <div class="row" id="orders">

        @if (Model.Items != null && Model.Items.Any())
        {
            @foreach (var order in Model.Items)
            {
                <div id="order-@order.Id" class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow-sm border-0 h-100
                        @(order.IsError ? "border-warning bg-warning-subtle" : "")">

                        <div class="card-body">

                            <!-- HEADER -->
                            <div class="d-flex justify-content-between">

                                <h5 class="fw-bold">
                                    🍽 Table @order.TableId
                                </h5>

                                <span class="badge
                                    @(order.Status == "Completed" ? "bg-success" :
                                                                            order.Status == "Pending" ? "bg-warning text-dark" :
                                                                            "bg-secondary")">

                                    @order.Status
                                </span>

                            </div>
                            @if (order.IsError)
                {
                            <div class="mt-2">
                                <span class="badge bg-danger">
                                    ⚠ Has item out of stock
                                </span>
                            </div>
                }

                            <hr />

                            <!-- INFO -->
                            <p class="mb-2">
                                <strong>Time:</strong><br />
                                @order.OrderTime.ToString("dd/MM/yyyy HH:mm")
                            </p>

                            <p class="mb-2">
                                <strong>Total:</strong><br />
                                <span class="text-danger fw-bold fs-5">
                                    @order.TotalAmount.ToString("N0") VNĐ
                                </span>
                            </p>

                            @if (!string.IsNullOrEmpty(order.Note))
                            {
                                <p class="text-muted">
                                    📝 @order.Note
                                </p>
                            }

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-white border-0">

                            <div class="d-flex justify-content-between">

                                <a asp-action="Details"
                                       asp-route-id="@order.Id"
                                       class="btn btn-outline-primary btn-sm">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                       asp-route-id="@order.Id"
                                       class="btn btn-outline-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@order.Id"
                                       class="btn btn-outline-danger btn-sm">
                                    Delete
                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="text-center text-muted">
                No orders found.
            </div>
        }

    </div>

    <!-- PAGINATION -->
    @{
        int totalPages =
        (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
    }

    <nav>
        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">

                    <a class="page-link"
                           asp-action="Index"
                           asp-route-PageNumber="@i"
                           asp-route-TableNumber="@query?.TableNumber"
                           asp-route-Status="@query?.Status">

                        @i
                    </a>

                </li>
            }

        </ul>
    </nav>

</div>
