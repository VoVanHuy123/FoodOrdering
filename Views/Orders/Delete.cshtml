@model FoodOrdering.DTOs.OrderDTO

@{
    ViewData["Title"] = "Delete order";
    ViewData["FullWidth"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="admin-surface py-4">
    <div class="container admin-page" style="max-width: 720px;">

        <header class="admin-page__header mb-4">
            <h1 class="admin-page__title">Delete order</h1>
        </header>

        <section class="admin-panel border-danger" style="border-width: 1px; border-style: solid;">
            <div class="admin-panel__head border-danger border-opacity-25" style="background: #fef2f2;">
                <h2 class="admin-panel__title text-danger mb-0">Confirm deletion</h2>
            </div>
            <div class="p-4">
                <dl class="row mb-4 small">
                    <dt class="col-sm-4 text-muted">Order ID</dt>
                    <dd class="col-sm-8 fw-semibold">#@Model.Id</dd>
                    <dt class="col-sm-4 text-muted">Table</dt>
                    <dd class="col-sm-8">@(Model.TableNumber > 0 ? Model.TableNumber.ToString() : Model.TableId.ToString())</dd>
                    <dt class="col-sm-4 text-muted">Order time</dt>
                    <dd class="col-sm-8 admin-table__mono">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</dd>
                    <dt class="col-sm-4 text-muted">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>
                    <dt class="col-sm-4 text-muted">Total</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.TotalAmount.ToString("N0") đ</dd>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <dt class="col-sm-4 text-muted">Note</dt>
                        <dd class="col-sm-8">@Model.Note</dd>
                    }
                </dl>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i> Delete permanently
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </section>

    </div>
</div>
