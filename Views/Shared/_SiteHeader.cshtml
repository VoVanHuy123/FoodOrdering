@* Main navigation — shared across all pages *@
<nav class="navbar navbar-expand-lg site-navbar border-bottom site-navbar-main">
    <div class="container">
        <a class="navbar-brand site-brand fw-semibold" asp-controller="Home" asp-action="Index">
            FoodOrdering
        </a>

        <button class="navbar-toggler site-nav-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#siteNavbarMenu" aria-controls="siteNavbarMenu" aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-lg-end" id="siteNavbarMenu">
            <ul class="navbar-nav ms-lg-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1 text-end flex-wrap">
                <li class="nav-item">
                    <a class="nav-link site-nav-link" asp-controller="Home" asp-action="Index">
                        Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link site-nav-link" asp-controller="Home" asp-action="Index" asp-fragment="story">
                        Our story
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link site-nav-link" asp-controller="MenuItems" asp-action="Index">
                        Menu
                    </a>
                </li>
                
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link site-nav-link" asp-controller="Orders" asp-action="Index">
                            <i class="bi bi-receipt d-lg-none me-1"></i> Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link site-nav-link" asp-controller="Tables" asp-action="Index">
                            <i class="bi bi-grid d-lg-none me-1"></i> Tables
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link site-nav-link" asp-controller="Categories" asp-action="Index">
                                Categories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link site-nav-link" asp-controller="Users" asp-action="Index">
                                Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link site-nav-link" asp-controller="Reports" asp-action="Index">
                                Reports
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm site-btn-outline ms-lg-1 mt-2 mt-lg-0">Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-sm site-btn-primary mt-2 mt-lg-0" asp-controller="Auth" asp-action="Login">Sign in</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>
