
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - FoodOrdering</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ICON -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
          rel="stylesheet">

    <!-- GOOGLE FONTS -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Poppins:wght@300;400;500;600&display=swap"
          rel="stylesheet">
    
    <!-- Toastr -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        :root {
            --cream: #fffbeb;
            --cream-dark: #fef3c7;
            --butter: #fde68a;
            --mustard: #ca8a04;
            --gold: #eab308;
            --ink: #1c1917;
            --ink-muted: #57534e;
            --site-navbar-height: 4.5rem;
        }

        #toast-container > .toast {
            opacity: 1 !important;
            color: #ffffff !important;
            font-family: 'Poppins', sans-serif !important;
        }

        #toast-container > .toast-warning { background-color: #f89406 !important; }
        #toast-container > .toast-info { background-color: #17a2b8 !important; }
        #toast-container > .toast-success { background-color: #28a745 !important; }
        #toast-container > .toast-error { background-color: #dc3545 !important; }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
        }

        .font-serif {
            font-family: 'Playfair Display', Georgia, serif;
        }

        /* ===== SITE HEADER (partial _SiteHeader) ===== */
        .site-navbar {
            background: var(--cream);
            box-shadow: 0 2px 12px rgba(28, 25, 23, 0.06);
        }

        .site-brand {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 1.35rem;
            color: var(--ink) !important;
            letter-spacing: -0.02em;
        }

        .site-nav-link {
            color: var(--ink) !important;
            font-weight: 500;
            font-size: 0.95rem;
        }

            .site-nav-link:hover {
                color: var(--mustard) !important;
            }

        .site-btn-primary {
            background: var(--mustard);
            color: #fff !important;
            border: none;
            font-weight: 600;
            padding: 0.45rem 1.1rem;
        }

            .site-btn-primary:hover {
                background: #a16207;
                color: #fff !important;
            }

        .site-btn-outline {
            border: 1px solid var(--ink);
            color: var(--ink) !important;
            background: transparent;
            font-weight: 500;
        }

            .site-btn-outline:hover {
                background: var(--ink);
                color: #fff !important;
            }

        .site-nav-toggler {
            border: 1px solid #d6d3d1;
        }

        .site-navbar-main .navbar-collapse {
            flex-grow: 1;
        }

        /* ===== FOOTER ===== */
        .footer-custom {
            background: var(--cream-dark);
            color: var(--ink-muted);
            padding: 40px 0;
            border-top: 1px solid #e7e5e4;
        }

        .footer-title {
            font-family: 'Playfair Display', Georgia, serif;
            font-weight: 600;
            margin-bottom: 15px;
            color: var(--ink);
        }

        .footer-link {
            color: var(--ink-muted);
            text-decoration: none;
        }

            .footer-link:hover {
                color: var(--mustard);
            }

        .copyright {
            border-top: 1px solid #e7e5e4;
            margin-top: 25px;
            padding-top: 15px;
            text-align: center;
            font-size: 14px;
            color: var(--ink-muted);
        }
    </style>
</head>

<body class="@(ViewData["HomeFullViewportHero"] as bool? == true ? "body-home-hero" : string.Empty)">

    <header class="site-header sticky-top">
        @await Html.PartialAsync("_SiteHeader")
    </header>

    <!-- ================= CONTENT ================= -->
    <div class="@(ViewData["FullWidth"] as bool? == true ? "" : "container mt-4")">
        <main>
            <div id="notification-container"
                 style="
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    z-index: 9999;">
            </div>
            @RenderBody()
        </main>
    </div>

    <!-- ================= FOOTER ================= -->
    <footer class="footer-custom mt-auto mt-4">
        <div class="container">

            <div class="row">

                <!-- Brand -->
                <div class="col-md-4">
                    <h5 class="footer-title">FoodOrdering</h5>
                    <p>
                        Smart restaurant ordering system.
                        QR ordering, kitchen realtime, fast payment.
                    </p>
                </div>

                <!-- Navigation -->
                <div class="col-md-4">
                    <h5 class="footer-title">Navigation</h5>

                    <p><a asp-controller="Home" asp-action="Index" class="footer-link">Home</a></p>
                    <p><a asp-controller="MenuItems" asp-action="Index" class="footer-link">Menu</a></p>
                    @if (User.IsInRole("Admin"))
                    {
                        <p><a asp-controller="Categories" asp-action="Index" class="footer-link">Categories</a></p>
                    }
                    <p><a asp-controller="Home" asp-action="Privacy" class="footer-link">Privacy</a></p>

                </div>

                <!-- Contact -->
                <div class="col-md-4">
                    <h5 class="footer-title">Contact</h5>

                    <p><i class="bi bi-envelope"></i> support@foodordering.com</p>
                    <p><i class="bi bi-telephone"></i> +84 123 456 789</p>
                    <p><i class="bi bi-geo-alt"></i> Ho Chi Minh City</p>

                    <h5 class="footer-title mt-4">Follow us</h5>
                    <p class="mb-1">
                        <a href="#" class="footer-link"><i class="bi bi-instagram me-1"></i>Instagram</a>
                    </p>
                    <p class="mb-0">
                        <a href="#" class="footer-link"><i class="bi bi-facebook me-1"></i>Facebook</a>
                    </p>
                </div>

            </div>

            <div class="copyright">
                © 2026 FoodOrdering — All rights reserved
            </div>

        </div>
    </footer>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/orderHub.js"></script>
     <script src="~/js/notifyHub.js"></script> 

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>