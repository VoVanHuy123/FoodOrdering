@model FoodOrdering.DTOs.MenuItemDTO

@{
    ViewData["Title"] = "Menu item details";
    ViewData["FullWidth"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="admin-surface py-4">
    <div class="container admin-page">
        <header class="admin-page__header d-flex flex-column flex-md-row justify-content-md-between align-items-md-start gap-3 mb-4">
            <div>
                <h1 class="admin-page__title">@Model.Name</h1>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary border-0 bg-white shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to menu
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-admin-primary">
                        <i class="bi bi-pencil me-1"></i> Edit item
                    </a>
                }
            </div>
        </header>

        <div class="row g-4">
            <div class="col-lg-5">
                <section class="admin-panel h-100">
                    <div class="admin-panel__head">
                        <h2 class="admin-panel__title">Menu preview</h2>
                    </div>
                    <div class="p-4 text-center">
                        <div class="rounded-4 overflow-hidden border shadow-sm">
                            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/imgs/food.png") : Model.ImageUrl)"
                                 class="w-100"
                                 style="height: 360px; object-fit: cover;" />
                        </div>
                        <div class="mt-3">
                            <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary") me-2">
                                @(Model.IsAvailable ? "Available" : "Out of Stock")
                            </span>
                            <span class="badge bg-warning text-dark">
                                @Model.CategoryName
                            </span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-lg-7">
                <section class="admin-panel h-100">
                    <div class="admin-panel__head">
                        <h2 class="admin-panel__title">Item details</h2>
                    </div>
                    <div class="p-4">
                        <dl class="row mb-4 small text-muted">
                            <dt class="col-sm-4">Price</dt>
                            <dd class="col-sm-8 fw-semibold">$@Model.Price.ToString("N0")</dd>

                            <dt class="col-sm-4">Category</dt>
                            <dd class="col-sm-8">@Model.CategoryName</dd>

                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary")">
                                    @(Model.IsAvailable ? "Available" : "Out of Stock")
                                </span>
                            </dd>
                        </dl>

                        <div class="border rounded-4 p-4" style="background: #f8fafc; border-color: var(--admin-border);">
                            <h3 class="h6 mb-3 text-muted">Description</h3>
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

                        </a>
                    }

                    <a asp-action="Index"
                           class="btn btn-outline-secondary action-btn">
                        ← Back Menu
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>