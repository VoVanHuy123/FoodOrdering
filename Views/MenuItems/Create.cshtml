@model FoodOrdering.DTOs.MenuItemDTO

@{
    ViewData["Title"] = "Create Menu Item";
}


<div class="row mt-2 mb-4">

    <!-- LEFT IMAGE PREVIEW -->
    <div class="col-md-4 text-center">

        <div class="card shadow-sm p-3">

            <h6 class="fw-bold mb-3">Image Preview</h6>

            <img id="previewImage"
                 src="~/imgs/food.png"
                 class="img-fluid rounded"
                 style="height:300px; object-fit:cover;" />

        </div>

    </div>


    <!-- RIGHT FORM -->
    <div class="col-md-8">

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- NAME -->
            <div class="form-group mb-3">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" />
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group mb-3">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
            </div>

            <!-- PRICE -->
            <div class="form-group mb-3">
                <label asp-for="Price"></label>
                <input asp-for="Price"
                       type="number"
                       step="0.01"
                       class="form-control" />
            </div>

            <!-- IMAGE -->
            <div class="form-group mb-3">
                <label>Upload Image</label>
                <input asp-for="ImageFile"
                       type="file"
                       class="form-control"
                       accept="image/*"
                       onchange="previewFile(event)" />
            </div>

            <!-- AVAILABLE -->
            <div class="form-check mb-3">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable"></label>
            </div>

            <!-- CATEGORY -->
            <div class="form-group mb-3">
                <label asp-for="CategoryId"></label>
                <select asp-for="CategoryId"
                        class="form-control"
                        asp-items="ViewBag.CategoryId">
                </select>

            </div>

            <button class="btn btn-primary">
                Create
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Back
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewFile(event) {

            const input = event.target;
            const preview = document.getElementById("previewImage");

            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function(e) {
                    preview.src = e.target.result;
                };

                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

