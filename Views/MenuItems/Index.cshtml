@using FoodOrdering.DTOs

@model PagedResult<MenuItemDTO>
@{
    ViewData["Title"] = "Menu items";
    var categoryId = int.TryParse(ViewContext.HttpContext.Request.Query["CategoryId"], out var cid) ? cid : 0;
    var searchText = ViewContext.HttpContext.Request.Query["Search"].ToString();
    int totalPages = Model.PageSize > 0
        ? (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize)
        : 0;
}

<style>
    .menu-link {
        display: block;
        padding: 10px 0;
        color: #475569;
        text-decoration: none;
        border-bottom: 1px dashed #e2e8f0;
    }

    .menu-link:hover,
    .menu-link.active {
        color: #ca8a04;
        font-weight: 600;
    }

    .menu-card {
        transition: transform .25s ease, box-shadow .25s ease;
        border-radius: 16px;
        overflow: hidden;
    }

    .menu-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.12);
    }

    .menu-card img {
        height: 220px;
        object-fit: cover;
    }

    .menu-card .card-body {
        min-height: 140px;
    }

    .menu-card .badge {
        font-size: 0.75rem;
    }

    .menu-meta {
        font-size: 0.9rem;
        color: #64748b;
    }
    .font_head{
        font-family: "Playfair Display", Georgia, serif;
    }
</style>
@if (User.IsInRole("Admin"))
{
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class=" font_head">Menu manager</h2>

            <div>
                <a asp-action="Create" class="btn btn-success">
                    + Create menu item
                </a>
                <a asp-controller="Categories"
                       asp-action="Index"
                       class="btn btn-success">
                    + Categories
                </a>
            </div>
            
        </div>
    </div>
}


<div class="container-fluid mt-4">
    


    <div class="row">
        
        <!-- LEFT SIDEBAR -->
        <div class="col-md-3">

            <!-- Categories -->
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold">CATEGORIES</h6>
                    <ul class="list-unstyled mt-3">
                        <li>
                            <a href="?" class="menu-link">all</a>
                        </li>
                        @foreach (var c in ViewBag.Categories)
                        {
                            <li>
                                <a href="?CategoryId=@c.Id" class="menu-link">@c.Name</a>
                            </li>
                        }
                        <li>
                            <a href="/Categories" class="menu-link">
                                 Manage Categories
                            </a>
                        </li>
                        
                    </ul>
                </div>
            </div>

            <!-- Search -->
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <form method="get">
                        <div class="input-group">
                            <input name="Search" class="form-control" placeholder="Search..." />
                            <button class="btn btn-warning">🔍</button>
                        </div>
                    </form>
                </div>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center">


                        <a asp-controller="MenuItems"
                               asp-action="Create"
                               class="btn btn-warning w-100 fw-bold">
                            ➕ Add Menu Item
                        </a>

                    </div>
                </div>
            }

        </div>

        <!-- RIGHT CONTENT -->
        <div class="col-md-9">

            <div class="row">

                @foreach (var item in Model.Items)
                {
                    <div class="col-md-4 mb-4">

                        <a href="@Url.Action("Details", "MenuItems", new { id = item.Id })" style="text-decoration:none;color:inherit;">
                            <div class="card menu-card h-100 border-0 shadow-sm">
                                <div class="position-relative">
                                    <span class="badge bg-warning position-absolute top-0 start-0 m-3">@item.CategoryName</span>
                                    <span class="badge position-absolute top-0 end-0 m-3 @(item.IsAvailable ? "bg-success" : "bg-secondary")">@(item.IsAvailable ? "Available" : "Out of Stock")</span>
                                </div>
                                <img src="@(
                                        string.IsNullOrEmpty(item.ImageUrl)
                                            ? Url.Content("~/imgs/food.png")
                                            : item.ImageUrl
                                    )"
                                     class="card-img-top"
                                     style="height:200px; object-fit:cover;" />

                                <div class="card-body text-center">
                                    <h6 class="fw-bold">@item.Name</h6>
                                    <p class="text-danger fw-bold">
                                        $ @item.Price
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                }

            </div>

        </div>

    </div>

</div>
