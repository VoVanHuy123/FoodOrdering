@model FoodOrdering.DTOs.MenuItemDTO

@{
    ViewData["Title"] = "Delete menu item";
    ViewData["FullWidth"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="admin-surface py-4">
    <div class="container admin-page" style="max-width: 840px;">
        <header class="admin-page__header mb-4">
            <h1 class="admin-page__title">Delete menu item</h1>
            <p class="admin-page__meta mb-0">This will permanently remove the menu item from the catalog.</p>
        </header>

        <section class="admin-panel border-danger" style="border-width: 1px; border-style: solid;">
            <div class="admin-panel__head border-danger border-opacity-25" style="background: #fef2f2;">
                <h2 class="admin-panel__title text-danger mb-0">Confirm deletion</h2>
            </div>
            <div class="row g-4 p-4">
                <div class="col-md-5">
                    <div class="rounded-4 overflow-hidden border shadow-sm">
                        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/imgs/food.png") : Model.ImageUrl)"
                             class="w-100"
                             style="height: 320px; object-fit: cover;" />
                    </div>
                </div>
                <div class="col-md-7">
                    <dl class="row mb-4 small text-muted">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Name</dd>

                        <dt class="col-sm-4">Category</dt>
                        <dd class="col-sm-8">@Model.CategoryName</dd>

                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8">$@Model.Price.ToString("N0")</dd>

                        <dt class="col-sm-4">Availability</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary")">
                                @(Model.IsAvailable ? "Available" : "Out of Stock")
                            </span>
                        </dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    </dl>

                    <form asp-action="Delete" method="post" class="d-flex flex-wrap gap-2">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i> Delete permanently
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </section>
    </div>
</div>
