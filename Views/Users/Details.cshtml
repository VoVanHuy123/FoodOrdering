@model FoodOrdering.DTOs.UserDTO

<style>
    .card {
        border-radius: 15px;
    }

    .badge {
        font-size: 0.9rem;
    }

    img.rounded-circle {
        border: 4px solid #fff;
    }
</style>

<div class="container mt-2 mb-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 text-center">

                <!-- Header -->
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fa fa-user me-2"></i>User Details
                    </h4>
                </div>

                <!-- Avatar -->
                <div class="mt-4">
                    <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=random"
                         class="rounded-circle shadow"
                         width="100" height="100" />
                </div>

                <!-- Body -->
                <div class="card-body">

                    <h5 class="fw-bold mt-2">@Model.FullName</h5>
                    <p class="text-muted">@Model.Username</p>

                    <!-- Role badge -->
                    <div class="mb-3">
                        @if (Model.Role == "Admin")
                        {
                            <span class="badge bg-danger px-3 py-2">Admin</span>
                        }
                        else if (Model.Role == "Manager")
                        {
                            <span class="badge bg-primary px-3 py-2">Manager</span>
                        }
                        else
                        {
                            <span class="badge bg-success px-3 py-2">Staff</span>
                        }
                    </div>

                    <hr />

                    <!-- Info -->
                    <div class="text-start px-4">
                        <p><i class="fa fa-id-card me-2 text-secondary"></i><b>ID:</b> @Model.Id</p>
                        <p><i class="fa fa-user me-2 text-secondary"></i><b>Username:</b> @Model.Username</p>
                        <p><i class="fa fa-user-tag me-2 text-secondary"></i><b>Role:</b> @Model.Role</p>
                    </div>

                </div>

                <!-- Footer -->
                <div class="card-footer bg-white border-0 pb-4">

                    <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning me-2">
                        <i class="fa fa-edit me-1"></i>Edit
                    </a>

                    <a asp-action="Index"
                           class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left me-1"></i>Back
                    </a>

                </div>

            </div>

        </div>
    </div>
    ```

</div>
