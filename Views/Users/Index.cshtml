
@using FoodOrdering.DTOs
@model List<FoodOrdering.DTOs.UserDTO>
@{
    ViewData["Title"] = "Users";
    ViewData["FullWidth"] = true;
    var query = ViewBag.Query as UsersQuery;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="admin-surface py-4">
    <div class="container admin-page">

        <header class="admin-page__header d-flex flex-column flex-md-row justify-content-md-between align-items-md-start gap-3">
            <div>
                <h1 class="admin-page__title">Users</h1>
                <p class="admin-page__meta mb-0">Search users by name and role.</p>
            </div>
            <a asp-action="Create" class="btn btn-admin-primary">
                <i class="bi bi-plus-lg me-1"></i> New user
            </a>
        </header>

        <form method="get" class="admin-toolbar">
            <div class="row g-3 align-items-end">
                <div class="col-md-4 col-lg-3">
                    <div class="admin-toolbar__label">Name</div>
                    <input type="text"
                           name="Name"
                           value="@query?.Name"
                           class="form-control"
                           placeholder="Search name or username"
                           autocomplete="off" />
                </div>
                <div class="col-md-3 col-lg-2">
                    <div class="admin-toolbar__label">Role</div>
                    <select name="Role" class="form-select">
                        @if (string.IsNullOrEmpty(query?.Role))
                        {
                            <option value="" selected>All roles</option>
                        }
                        else
                        {
                            <option value="">All roles</option>
                        }

                        @if (query?.Role == "Admin")
                        {
                            <option value="Admin" selected>Admin</option>
                        }
                        else
                        {
                            <option value="Admin">Admin</option>
                        }

                        @if (query?.Role == "Manager")
                        {
                            <option value="Manager" selected>Manager</option>
                        }
                        else
                        {
                            <option value="Manager">Manager</option>
                        }

                        @if (query?.Role == "Staff")
                        {
                            <option value="Staff" selected>Staff</option>
                        }
                        else
                        {
                            <option value="Staff">Staff</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 col-lg-2">
                    <button type="submit" class="btn btn-admin-primary w-100">
                        <i class="bi bi-funnel me-1"></i> Apply
                    </button>
                </div>
            </div>
        </form>

        <section class="admin-panel">
            <div class="admin-panel__head">
                <h2 class="admin-panel__title">User list</h2>
                <span class="small text-muted font-monospace">@Model.Count total</span>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="admin-table-wrap">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Username</th>
                                <th scope="col">Role</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle bg-secondary" style="width:40px;height:40px;"></div>
                                            <span class="fw-medium">@user.FullName</span>
                                        </div>
                                    </td>
                                    <td class="text-muted">@user.Username</td>
                                    <td>
                                        @if (user.Role == "Admin")
                                        {
                                            <span class="admin-badge admin-badge--cancelled">Admin</span>
                                        }
                                        else if (user.Role == "Manager")
                                        {
                                            <span class="admin-badge admin-badge--preparing">Manager</span>
                                        }
                                        else
                                        {
                                            <span class="admin-badge admin-badge--completed">Staff</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="admin-actions justify-content-end">
                                            <a asp-action="Details" asp-route-id="@user.Id" class="admin-btn-icon">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@user.Id" class="admin-btn-icon">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@user.Id" class="admin-btn-icon admin-btn-icon--danger">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="admin-empty">
                    <i class="bi bi-inbox d-block"></i>
                    <p class="mb-0 fw-medium">No users match your filters.</p>
                    <p class="small mb-0 mt-1">Try removing filters or create a new user.</p>
                </div>
            }
        </section>

    </div>
</div>