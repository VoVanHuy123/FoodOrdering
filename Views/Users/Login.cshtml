<h2>Login</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form method="post">

    <input name="Username"
           class="form-control mb-2"
           placeholder="Username" />

    <input name="Password"
           type="password"
           class="form-control mb-2"
           placeholder="Password" />

    <button class="btn btn-primary">Login</button>

</form>