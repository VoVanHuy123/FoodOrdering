@model FoodOrdering.DTOs.TableDTO

@{
    ViewData["Title"] = "Delete Table";
}

<div class="container mt-2 mb-4">
    <div class="card shadow border-0">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">⚠ Delete Table</h4>
        </div>

        <div class="card-body">

            <h5 class="text-danger mb-4">
                Are you sure you want to delete this table?
            </h5>

            <dl class="row">

                <dt class="col-sm-3 fw-bold">
                    Table Number
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.TableNumber)
                </dd>

                <dt class="col-sm-3 fw-bold">
                    QR Code
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.QRCode)
                </dd>

                <dt class="col-sm-3 fw-bold">
                    Status
                </dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info">
                        @Html.DisplayFor(model => model.Status)
                    </span>
                </dd>

            </dl>

            <hr />

            <form asp-action="Delete">

                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger">
                    🗑 Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    ← Cancel
                </a>

            </form>

        </div>
    </div>
</div>