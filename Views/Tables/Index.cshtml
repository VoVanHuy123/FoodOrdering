@model IEnumerable<FoodOrdering.DTOs.TableDTO>

@{
    ViewData["Title"] = "Tables";
}
<style>
.font_head{
    font-family: "Playfair Display", Georgia, serif;
}
</style>

<div class="container mt-2 mb-4">
    @if(User.IsInRole("Admin"))
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class=" font_head">Restaurant Tables</h2>

            <a asp-action="Create" class="btn btn-success">
                + Create Table
            </a>
        </div>
    }
    

    <div class="row">

        @foreach (var table in Model)
        {
            var statusClass =
                table.Status == "Available" ? "bg-success" :
                table.Status == "Occupied" ? "bg-danger" :
                table.Status == "Reserved" ? "bg-warning text-dark" :
                "bg-secondary";

            <div class="col-md-4 col-lg-3 mb-4">

                <div class="card shadow-sm border-0 h-100">

                    <div class="card-body text-center">

                        <!-- TABLE NUMBER -->
                        <h3 class="fw-bold mb-2">
                            🍽 Table @table.TableNumber
                        </h3>

                        <!-- STATUS -->
                        <span class="badge @statusClass mb-3 px-3 py-2" id="table_@table.TableNumber">
                            @table.Status
                        </span>

                        <!-- QR CODE -->
                        @if (!string.IsNullOrEmpty(table.QRCode))
                        {
                            <div class="mb-3">
                                <img src="@table.QRCode"
                                     class="img-fluid rounded shadow"
                                     style="max-height:120px;" />
                            </div>
                        }

                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="card-footer bg-white border-0">
                        <div class="d-flex justify-content-between">

                            <a asp-action="Details"
                                   asp-route-id="@table.Id"
                                   class="btn btn-outline-primary btn-sm">
                                Details
                            </a>

                            <a asp-action="Edit"
                                   asp-route-id="@table.Id"
                                   class="btn btn-outline-warning btn-sm">
                                Edit
                            </a>
                            @if(User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete"
                                       asp-route-id="@table.Id"
                                       class="btn btn-outline-danger btn-sm">
                                    Delete
                                </a>
                            }
                            

                        </div>
                    </div>

                </div>

            </div>
        }

    </div>

</div>
@section Scripts {
    <script src="~/js/orderHub.js"></script>
}